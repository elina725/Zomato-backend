# MySQL connection URL used by Sequelize.
MYSQL_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

# Use a long, random value in Railway; do not rely on the development fallback.
JWT_SECRET=replace-with-a-long-random-secret

# Set false until Razorpay is configured.
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
